pipeline {
    agent any

    tools {
        // Install the Maven version configured as "M398" and add it to the path.
        maven "M398"
    }

    stages {
        stage("Echo Version"){
            steps{
                sh 'echo print Maven version'
                sh 'mvn -version'
            }
        }
        stage('Build'){
            steps{
                dir('demo'){
                    sh 'mvn clean package -DskipTests=true'
                }
            }
        }
        stage('Test'){
            steps{
                for(int i=0;i<60;i++){
                    echo "$(i+1)"
                    sleep 1
                }
                dir('demo'){
                    sh 'mvn test'
                }
            }
        }
    }
}
