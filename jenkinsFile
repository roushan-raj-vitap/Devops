pipeline {
    agent any

    tools {
        // Install the Maven version configured as "M398" and add it to the path.
        maven "M398"
    }

    stages {
        stage("Echo Version"){
            steps{
                sh 'echo print Maven version'
                sh 'mvn -version'
            }
        }
        stage('checkout'){
            steps{
                // git branch: 'master', url: 'https://github.com/roushan-raj-vitap/Devops.git'
            }
        }
        stage('Build'){
            steps{
                dir('demo'){
                    sh 'mvn clean package -DskipTests=true'
                }
            }
        }
        stage('Test'){
            steps{
                dir('demo'){
                    sh 'mvn test'
                }
            }
        }
    }
}
